{
    "name": "dhrynko/linked-list-sorter",
    "description": "A library providing sorted linked lists.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "LinkedListSorter\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LinkedListSorter\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.5",
        "symfony/console": "^8.0",
        "symfony/dependency-injection": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "phpstan/phpstan": "^2.1",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse src tests --level=9",
        "phpcs": "phpcs --standard=PSR12 src tests",
        "phpcbf": "phpcbf --standard=PSR12 src tests",
        "check": [
            "@phpcs",
            "@phpstan",
            "@test"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "symfony/flex": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
